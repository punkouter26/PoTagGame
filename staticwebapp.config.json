{
  "routes": [
    {
      "route": "/tagHub/*",
      "allowedRoles": ["anonymous"],
      "rewrite": "/tagHub/{*}"
    },
    {
      "route": "/*",
      "serve": "/index.html",
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/sprites/*", "/assets/*", "*.css", "*.js", "*.png", "*.ico"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  }
}
