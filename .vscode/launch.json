{
  "version": "0.2.0",
  "compounds": [
    {
      "name":           "PoTagGame: Full Stack",
      "configurations": [ "PoTagGame: Server", "PoTagGame: Client" ],
      "stopAll":        true
    }
  ],
  "configurations": [
    {
      "name":            "PoTagGame: Server",
      "type":            "coreclr",
      "request":         "launch",
      "preLaunchTask":   "build-server",
      "program":         "${workspaceFolder}/src/server/bin/Debug/net10.0/PoTagGame.dll",
      "args":            [],
      "cwd":             "${workspaceFolder}/src/server",
      "stopAtEntry":     false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "PoTagGame: Client",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src/client",
      "preLaunchTask": "start-client"
    },
    {
      // Standalone server-only debug (no client)
      "name":          "PoTagGame: Server Only",
      "type":          "coreclr",
      "request":       "launch",
      "preLaunchTask": "build-server",
      "program":       "${workspaceFolder}/src/server/bin/Debug/net10.0/PoTagGame.dll",
      "args":          [],
      "cwd":           "${workspaceFolder}/src/server",
      "stopAtEntry":   false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ]
}
