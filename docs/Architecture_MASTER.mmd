flowchart TB
    %% ── C4 Level 1: Context ──
    subgraph Context["System Context"]
        User["Browser Client"]
        SWA["Azure Static Web App"]
    end

    User -->|"HTTPS / WSS"| SWA

    %% ── C4 Level 2: Containers ──
    subgraph EdgeDelivery["Edge Delivery"]
        CDN["SWA CDN"]
        StaticAssets["Static Assets\nHTML · CSS · JS · Sprites"]
    end

    subgraph ComputeTier["Compute Tier"]
        ViteSPA["React 18 SPA\nVite · TypeScript · Canvas 2D"]
        SignalRHub["TagHub\nSignalR WebSocket"]
        MinimalAPI["ASP.NET Core 10\nMinimal API · Scalar OpenAPI"]
        BGService["GameBackgroundService\n1 Hz Timer Tick"]
    end

    subgraph DataPersistence["Data Persistence"]
        GameService["GameService Singleton\nThread-safe In-Memory State"]
        GameRoom["GameRoom Aggregate\nPlayers · Phase · Rounds"]
        ReplayStore["ReplayRecorder\n~700 Frames Buffer"]
        ArenaJSON["arenas.json\nShared Arena Definitions"]
    end

    %% ── Edge → Compute flows ──
    CDN -->|"Serves"| StaticAssets
    StaticAssets -->|"Loads into"| ViteSPA
    ViteSPA -->|"SignalR WSS\nJoinLobby · UpdatePosition · StartGame"| SignalRHub
    SignalRHub -->|"Delegates to"| MinimalAPI
    MinimalAPI -->|"Calls"| GameService

    %% ── Compute internal flows ──
    BGService -->|"1 Hz TimeTick\nRound End · Auto-Restart"| SignalRHub
    BGService -->|"Reads / Mutates"| GameService
    GameService -->|"Manages"| GameRoom
    GameService -->|"Records frames"| ReplayStore
    GameService -->|"Loads walls"| ArenaJSON

    %% ── Broadcast back to edge ──
    SignalRHub -->|"Broadcasts\nStateUpdated · GameStarted\nRoundEnded · GameEnded"| ViteSPA

