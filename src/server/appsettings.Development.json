{
  "ApplicationInsights": {
    "ConnectionString": "InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://local.in.applicationinsights.azure.com/"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173", "http://localhost:5000" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft":                                   "Information",
        "Microsoft.AspNetCore":                        "Information",
        "Microsoft.AspNetCore.Cors.Infrastructure":    "Warning",
        "System":                                      "Warning"
      }
    }
  }
}
